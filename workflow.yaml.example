# Workflow template
#
# The lifecycle order still comes from `statuses`, but the transition behavior
# now comes from `transitions`. The CLI should only expose and enforce what is
# declared here.
#
# Status fields:
#   - name: status identifier (used in issue frontmatter)
#   - description: shown in board column headers
#   - prompt: baseline guidance shown whenever an agent starts work in or enters this status
#
# Transition action types:
#   - validate:
#       rule: body_not_empty | has_checkboxes | section_has_checkboxes: X
#             | has_assignee | all_checkboxes_checked | section_checkboxes_checked: X
#             | has_test_plan | has_comment_prefix: X
#   - require_human_approval:
#       status: status that must already be present in `human_approval` frontmatter
#   - append_section:
#       title: section heading to create or reuse
#       body: markdown appended inside that section
#   - inject_prompt:
#       prompt: extra guidance surfaced for the next transition
#   - set_fields:
#       field: assignee | human_approval | priority | status
#       value: scalar string to set (empty string clears the field)
#
# Optional subsystem overlays:
#   systems:
#     Workflow:
#       statuses:
#         - name: "in design"
#           prompt: "Document workflow-specific transition, template, and compatibility changes."

statuses:
  - name: "idea"
    description: "Raw idea, needs exploration"
    prompt: |
      Clarify the issue with the human before moving into structured design.
      Ask focused questions to remove ambiguity around goals, scope, and success criteria.

  - name: "in design"
    description: "Being designed and specced out"
    prompt: |
      Review the relevant context before proposing changes.
      Turn the problem into explicit checklists, assumptions, and open questions.
      Write the design into the issue body under the relevant sections before checking the related boxes.
      When the design is complete, stop and ask for backlog approval in the issue viewer before attempting the transition.

  - name: "backlog"
    description: "Ready to work on"
    prompt: |
      This is a handoff state.
      Do not run `issue-cli start` until a human approves `in progress` in the issue viewer.

  - name: "in progress"
    description: "Actively being implemented"
    prompt: |
      Implement the accepted design and keep the issue body, implementation checklist, and test plan accurate as work progresses.
      Record implementation notes and planned verification steps in the issue body; checkboxes mark completion but do not replace written content.

  - name: "testing"
    description: "Under verification"
    prompt: |
      Build or update the relevant automated coverage, record concrete test evidence, and surface any remaining manual checks clearly.
      Before checking test-related boxes, make sure the Test Plan section in the issue body contains the explicit automated and manual steps being verified.

  - name: "human-testing"
    description: "Manual verification by humans"
    prompt: |
      Stop here and wait for human verification.
      Make sure the manual checks are explicit, minimal, and reproducible.

  - name: "documentation"
    description: "Being documented"
    prompt: |
      Update the relevant docs for the change and record the documentation work clearly.

  - name: "shipping"
    description: "Commit, push, and open a PR"
    prompt: |
      Commit the changes with a message referencing the issue, push to the remote, and (if applicable) open a PR.
      Tick the Shipping checklist as each step completes, then request human approval before marking done.

  - name: "done"
    description: "Completed"

transitions:
  - from: "idea"
    to: "in design"
    actions:
      - type: validate
        rule: body_not_empty
      - type: append_section
        title: Idea
        body: |
          - [ ] Description written with enough context for someone unfamiliar
          - [ ] Edge cases and constraints identified
          - [ ] Scope is clear (what is NOT included)
      - type: append_section
        title: Design
        body: |
          - [ ] Approach documented
          - [ ] Dependencies identified
          - [ ] Human approval requested for backlog
      - type: append_section
        title: Acceptance Criteria
        body: |
          - [ ] First observable requirement
          - [ ] Second observable requirement

  - from: "in design"
    to: "backlog"
    actions:
      - type: validate
        rule: "section_checkboxes_checked: Design"
      - type: validate
        rule: "section_has_checkboxes: Acceptance Criteria"
      - type: require_human_approval
        status: backlog
      - type: set_fields
        field: assignee
        value: ""

  - from: "backlog"
    to: "in progress"
    actions:
      - type: require_human_approval
        status: in progress
      - type: validate
        rule: has_assignee
      - type: append_section
        title: Implementation
        body: |
          - [ ] Code changes complete
          - [ ] Automated tests added or updated where practical
          - [ ] Cross-cutting impact reviewed where relevant
      - type: append_section
        title: Test Plan
        body: |
          ### Automated
          - [ ] Automated verification recorded

          ### Manual
          - [ ] Manual verification listed if needed
      - type: inject_prompt
        prompt: |
          Implement the change and keep the Implementation section accurate as work progresses.
          Call out cross-cutting impact early if the change affects shared state, shared config, or behavior outside the immediate subsystem.

  - from: "in progress"
    to: "testing"
    actions:
      - type: validate
        rule: "section_checkboxes_checked: Implementation"
      - type: validate
        rule: has_test_plan
      - type: append_section
        title: Testing
        body: |
          - [ ] Relevant tests for changed code passing
          - [ ] Known unrelated failures documented if full suite is red
          - [ ] Test results logged as comment (`issue-cli comment <slug> --text "tests: ..."`)
      - type: inject_prompt
        prompt: "Run the relevant tests for the changed code, record results, and capture any remaining manual checks. If unrelated failures block the full suite, document them explicitly."

  - from: "testing"
    to: "human-testing"
    actions:
      - type: validate
        rule: has_test_plan
      - type: validate
        rule: "section_checkboxes_checked: Testing"
      - type: validate
        rule: "has_comment_prefix: tests:"
      - type: append_section
        title: Human Testing
        body: |
          - [ ] Human verification complete if required

  - from: "human-testing"
    to: "documentation"
    actions:
      - type: require_human_approval
        status: documentation
      - type: append_section
        title: Documentation
        body: |
          - [ ] User-facing docs updated if behavior changed
          - [ ] Docs comment added (`issue-cli comment <slug> --text "docs: ..."`)

  - from: "documentation"
    to: "shipping"
    actions:
      - type: validate
        rule: "section_checkboxes_checked: Documentation"
      - type: validate
        rule: "has_comment_prefix: docs:"
      - type: append_section
        title: Shipping
        body: |
          - [ ] Changes committed with a message referencing the issue
          - [ ] Commit pushed to the remote
          - [ ] PR opened if applicable

  - from: "shipping"
    to: "done"
    actions:
      - type: validate
        rule: "section_checkboxes_checked: Shipping"
      - type: require_human_approval
        status: done

systems:
  Workflow:
    statuses:
      - name: "in design"
        prompt: |
          Review the relevant workflow and transition logic before proposing changes.
          State which statuses, rules, templates, or overlays will change, and whether existing issues need migration or compatibility handling.
          Write the design into the issue body under the relevant sections before checking the related boxes.
          When the design is complete, stop and ask for backlog approval in the issue viewer before attempting the transition.
  UI:
    statuses:
      - name: "in design"
        prompt: |
          Review the relevant context before proposing changes.
          Turn the problem into explicit checklists, assumptions, and open questions.
          Write the design into the issue body under the relevant sections before checking the related boxes.
          For UI work that launches local tools or editors, state whether to reuse existing tmux/alacritty patterns, whether handlers may block on local processes, and what feedback the user sees after launch.
          When the design is complete, stop and ask for backlog approval in the issue viewer before attempting the transition.
  API:
    statuses:
      - name: "in design"
        prompt: |
          Review the relevant context before proposing changes.
          Turn the problem into explicit checklists, assumptions, and open questions.
          Write the design into the issue body under the relevant sections before checking the related boxes.
          For API changes that affect UI-visible state, state the source of truth, whether server-side polling plus `/hash` is the expected refresh path, and whether manual browser verification is required before human-testing.
          When the design is complete, stop and ask for backlog approval in the issue viewer before attempting the transition.
  CLI:
    statuses:
      - name: "in design"
        prompt: |
          Review the relevant context before proposing changes.
          Turn the problem into explicit checklists, assumptions, and open questions.
          Write the design into the issue body under the relevant sections before checking the related boxes.
          Document the output contract early: whether text is human-facing or agent-facing, whether script compatibility matters, and whether `--json` or other machine-readable output is in scope for this issue.
          When the design is complete, stop and ask for backlog approval in the issue viewer before attempting the transition.

# Ticket scoring (optional).
# When `enabled: true`, the viewer computes a score per issue from frontmatter
# and renders it as a badge on board cards, a chip + sortable option on the
# list view, and a breakdown in the detail sidebar. Omit the block or set
# `enabled: false` to hide all scoring UI.
#
# Formula (v1):
#   score = priority_weight
#         + min(overdue_cap, max(0, 30 - days_until_due) * urgency_weight)
#         + age_days * staleness_weight
#         + sum(label_weights for each label on the issue)
#         + score_boost                    # optional frontmatter override
#
# Frontmatter fields that participate: `priority`, `due`, `created`, `labels`,
# `score_boost`. Missing fields contribute 0.
#
# Priority keys are looked up after the frontmatter value is normalized to
# lowercase. Use lowercase keys (`p0`, `critical`) — frontmatter `P2` resolves
# as `p2`. Uppercase keys still match via a case-insensitive fallback but
# lowercase is the canonical form.
scoring:
  enabled: false
  formula:
    priority:
      critical: 40
      high: 20
      medium: 10
      low: 0
    due_date:
      urgency_weight: 2   # points per day under 30-day horizon
      overdue_cap: 60     # cap overdue contribution
    age:
      staleness_weight: 0.1
    labels:
      bug: 5
      blocker: 25
      enhancement: 0
  default_sort: score_desc   # or: created_desc, updated_desc
